# Job Application Agent — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values you need.
# Only the variables relevant to your setup are required.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── API Auth ────────────────────────────────────────────────────────────────
# Set a non-empty value to enable X-API-Key authentication on /api/* routes.
# API_KEY=

# ─── LLM API Keys ───────────────────────────────────────────────────────────
# Used by the Cover Letter Generator. At least one is recommended.
# Claude is tried first; OpenAI is the fallback.
CLAUDE_API_KEY=
OPENAI_API_KEY=

# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (async driver).
# Used by the API server and Celery workers.
# If PostgreSQL is unavailable, the system falls back to JSON file storage.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/job_agent

# Redis URL for Celery task queue and caching.
REDIS_URL=redis://localhost:6379/0

# ─── Vector Store ────────────────────────────────────────────────────────────
# Directory for ChromaDB persistent storage (embeddings).
CHROMA_PERSIST_DIR=./data/chroma

# ─── Web Scraping ────────────────────────────────────────────────────────────
# Firecrawl API key — free tier (1,000 pages/month).
# Used to scrape LinkedIn Jobs + Indeed for Product Manager listings.
# Get a key at https://www.firecrawl.dev (no credit card needed for free tier).
# Without a key, Firecrawl still works with lower rate limits.
FIRECRAWL_API_KEY=

# ─── Job Discovery ───────────────────────────────────────────────────────────
# LinkedIn scraping credentials (optional — enables Playwright-based LinkedIn job source).
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# Adzuna API — free tier, good job coverage (https://developer.adzuna.com).
ADZUNA_APP_ID=
ADZUNA_API_KEY=

# SerpAPI key (optional — enables Google Jobs search).
SERPAPI_KEY=

# ─── Email Notifications ─────────────────────────────────────────────────────
# Gmail SMTP for sending application confirmations / alerts.
# Generate an App Password at https://myaccount.google.com/apppasswords
GMAIL_EMAIL=
GMAIL_APP_PASSWORD=

# ─── Browser Automation ──────────────────────────────────────────────────────
# Run Playwright in headless mode (true) or show the browser window (false).
# Set to false for debugging CAPTCHA issues or watching automation in action.
BROWSER_HEADLESS=true

# Debug mode: launch with a visible browser for step-by-step debugging.
BROWSER_HEADED_DEBUG=false

# Directory for application screenshots (for debugging and review).
SCREENSHOTS_DIR=./data/screenshots

# Timeout (milliseconds) for page navigation and form interactions.
APPLY_TIMEOUT_MS=30000

# ─── Agent Behaviour ─────────────────────────────────────────────────────────
# Minimum match score (0.0–1.0) for a job to be considered for application.
MATCH_THRESHOLD=0.65

# Maximum number of applications to submit per day.
MAX_APPLICATIONS_PER_DAY=20

# When true, the agent pauses before submitting so you can review fields.
# Set to false for fully automated (hands-off) applications.
HUMAN_REVIEW_MODE=true

# ─── Storage Paths ───────────────────────────────────────────────────────────
# Base directory for all agent data (profiles, embeddings, cover letters).
DATA_DIR=./data

# Directory for parsed CV storage.
CV_STORAGE_DIR=./data/cvs

# Directory for generated cover letters.
COVER_LETTER_DIR=./data/cover_letters
